# Copy to .streamlit/secrets.toml for local development.
# For Streamlit Community Cloud, paste this into App settings → Secrets.
#
# ── Community leaderboard submissions (Google Apps Script) ──
# 1. Open the Google Sheet → Extensions → Apps Script
# 2. Paste resources/google_apps_script_submissions.gs → Save
# 3. Deploy → New deployment → Web app
#    Execute as: Me | Who has access: Anyone
# 4. Replace the URL below with your deployment URL
#
# Submissions are written directly to the Approved tab:
# - New player names are added automatically
# - Existing players can update only with a higher EX Rating
# Every submission is also appended to the Pending tab as a log (duplicates allowed).

pending_submission_url = "https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec"

# ── Full EX rating leaderboard (Supabase / SQLite — WIP, opt-in) ──
# The live site uses resources/full_ex_rating_leaderboard.csv by default.
# To switch the app to SQL after Supabase is ready, set:
#
# [leaderboard]
# use_sql = true
#
# [supabase]
# db_url = "postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@..."
#
# Schema: commit supabase/migrations/ and enable GitHub integration
# (Working directory: .). See resources/supabase_schema.sql for manual fallback.
# Data: python build_ex_leaderboard.py && python sync_ex_leaderboard_to_supabase.py

# [leaderboard]
# use_sql = true

[supabase]
db_url = "postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:6543/postgres"
