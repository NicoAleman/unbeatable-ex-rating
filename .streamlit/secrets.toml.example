# Copy to .streamlit/secrets.toml for local development.
# For Streamlit Community Cloud, paste this into App settings → Secrets.
#
# ── Community leaderboard submissions (Google Apps Script) ──
pending_submission_url = "https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec"

# ── Full EX rating leaderboard ──
# Baseline ratings: resources/ex_rating_baseline.csv (in repo, no ranks stored)
# Live rating patches: Supabase updated_ratings table (small fetch on page load)
# Top player scores: Supabase scores table (seed via sync_top_scores_to_supabase.py)
#
# Supabase → Connect → copy the Session pooler URI and replace YOUR_PASSWORD.

[supabase]
db_url = "postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres"
